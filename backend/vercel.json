{
  "version": 2,
  "functions": {
    "api/index.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index?__vercel_path=$1" },
    { "source": "/upload/(.*)", "destination": "/api/index?__vercel_path=upload/$1" },
    { "source": "/uploads/(.*)", "destination": "/api/index?__vercel_path=uploads/$1" }
  ]
}
