{
  "version": 2,
  "functions": {
    "api/index.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/upload/(.*)", "destination": "/api/index" },
    { "source": "/uploads/(.*)", "destination": "/api/index" }
  ]
}
