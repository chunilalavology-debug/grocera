# --- Vercel (grocera-ships) ---
# Root Directory MUST be: backend/zippyyy-ships-server  (not repo root, not backend/)
# Framework Preset: Other
# Build Command: npm run build
# Output Directory: (leave EMPTY — not "build")
# Install Command: npm install
# Vercel routing: api/health.js = lightweight /api/health; vercel.json routes send other paths to api/index.js (Express).
# After env changes: Redeploy.
#
PORT=3001
# Public URL of the ships UI (Stripe redirects + CORS). Embedded: e.g. https://yoursite.com/zippyyy-ships-app
APP_URL=http://localhost:8080

# Optional: comma-separated extra browser origins allowed to call this API (www, previews, etc.)
# CORS_ORIGINS=https://www.example.com,https://grocera-xxx.vercel.app

# Easyship — set on THIS Node service (not on the static frontend). Live tokens start with prod_
EASYSHIP_API_KEY=prod_your_live_token_here
# Safety guard: keep false in production so sandbox keys are rejected.
EASYSHIP_ALLOW_SANDBOX=false
# Default in code: apply_shipping_rules=false so dashboard rules don’t hide carriers. Re-enable with:
# EASYSHIP_APPLY_SHIPPING_RULES=1

# Stripe
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Commission added on top of Easyship live rate (default 30 means +30%)
ZIPPYYY_COMMISSION_PERCENT=30

# Backward-compatibility multiplier (kept at 1 to avoid double markup; commission handles pricing)
ZIPPYYY_MARKUP_MULTIPLIER=1

# Optional fee added on top of Easyship charge (in cents)
ZIPPYYY_FEE_CENTS=0

# Reference “list” price = Easyship total × this (for Save % UI; default 2 = vs ~2× negotiated rate)
ZIPPYYY_LIST_PRICE_MULTIPLIER=2

