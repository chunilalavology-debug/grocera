# --- Vercel (grocera-ships) ---
# Root Directory MUST be: backend/zippyyy-ships-server  (not repo root, not backend/)
# Framework Preset: Other
# Build Command: npm run build
# Output Directory: (leave EMPTY — not "build")
# Install Command: npm install
# After env changes: Redeploy.
#
PORT=3001
# Public URL of the ships UI (Stripe redirects + CORS). Embedded: e.g. https://yoursite.com/zippyyy-ships-app
APP_URL=http://localhost:8080

# Optional: comma-separated extra browser origins allowed to call this API (www, previews, etc.)
# CORS_ORIGINS=https://www.example.com,https://grocera-xxx.vercel.app

# Easyship — set on THIS Node service (not on the static frontend). Prod tokens start with prod_
EASYSHIP_API_KEY=sand_your_token_here

# Stripe
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Markup multiplier applied to Easyship rate total (default 1.25 = +25%)
ZIPPYYY_MARKUP_MULTIPLIER=1.25

# Optional fee added on top of Easyship charge (in cents)
ZIPPYYY_FEE_CENTS=0

# Reference “list” price = Easyship total × this (for Save % UI; default 2 = vs ~2× negotiated rate)
ZIPPYYY_LIST_PRICE_MULTIPLIER=2

