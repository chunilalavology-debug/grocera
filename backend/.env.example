# Copy to `.env` locally (never commit `.env`). See `.env.production.example` for the same template.
# If 5000 fails with EADDRINUSE (often on Windows), use PORT=5001 and point the frontend REACT_APP_API_URL at the same port.
PORT=5000
API_END_POINT_V1=/api
# Use either name on Vercel (code accepts both). Include database name in path, e.g. ...mongodb.net/mydb?...
MONGO_URI=mongodb+srv://<user>:<pass>@<cluster>/<db>?retryWrites=true&w=majority
DB_STRING=mongodb+srv://<user>:<pass>@<cluster>/<db>?retryWrites=true&w=majority
JWT_SECRET_KEY=<strong-secret>
# Exact browser origin(s) allowed by CORS (no trailing slash). Must match your live frontend URL.
# Comma-separated for multiple origins (e.g. production + preview).
FRONTEND_URL=https://your-frontend-project.vercel.app
# Optional extra origins (e.g. preview deployments)
# FRONTEND_URLS=https://grocera-xxx.vercel.app,https://grocera-git-main-xxx.vercel.app

# Public site origin (no path, no trailing slash). Used for profile/branding upload URLs when
# Express sees an internal Host (reverse proxy). Example: https://zippyyy.com
# API_PUBLIC_URL=https://your-public-domain.com

# Redis — required on Vercel (localhost is not available). Use Upstash or similar:
# REDIS_URL=rediss://default:<password>@<host>:6379

STRIPE_SECRET_KEY=<stripe-secret>
STRIPE_WEBHOOK_SECRET=<stripe-webhook-secret>
# Optional: log Stripe webhook handling (default off in production)
# STRIPE_WEBHOOK_DEBUG=1

EMAIL_USER=<smtp-user>
EMAIL_PASS=<smtp-pass>
# Inbox for contact form notifications (default in code: contact@zippyyy.com)
# CONTACT_FORM_TO_EMAIL=contact@zippyyy.com

CLOUDNARY_CLOUD_NAME=<cloud-name>
CLOUDNARY_API_KEY=<api-key>
CLOUDNARY_API_SECRET=<api-secret>

# Optional: shipping rates / labels (not required for product catalog)
# EASYSHIP_API_KEY=<easyship-token>
# Customer-facing margin on Easyship base quote (grocery POST /user/shipping/quote|checkout). Use one:
# EASYSHIP_QUOTE_MARKUP_PERCENT=30
# EASYSHIP_QUOTE_MARKUP_MULTIPLIER=1.3
