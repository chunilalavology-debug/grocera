############
# Profile
GET  {{url}}/auth/profile
Content-type: application/json
Authorization: {{token}}



############
# updateProfile
PUT  {{url}}/auth/updateProfile
Content-type: application/json
Authorization: {{token}}

{
  "firstName":"sa",
  "lastName":"kh",
  "phone":"",
  "address":{
    "street":"",
    "city":"",
    "state":"",
    "zipCode":"",
    "country":""
  }
}

############
# changePassword
