Content-type: application/json
Authorization: {{token}}

{
  "newPassword":"123456",
  "currentPassword":"321654"
}


############
# products
GET {{url}}/user/products?category=&search=&page=1&limit=20
Content-Type: application/json

############
# products get by id
GET   {{url}}/user/products/getById?id=6981d3fc70067af2d5ec90ff
Content-type: application/json

############
# subscription
POST  {{url}}/user/subscription/create
Content-Type: application/json
Authorization: {{token}}

{
  "productId": "65f1c9a2b8f7c12345678901",
  "quantity": 2,
  "frequency": "DAILY",
  "startDate": "2026-02-10",
}


############
# toggleSubscription
POST  {{url}}/user/toggleSubscription
Content-Type: application/json
Authorization: {{token}}

{
  "id":"65f1c9a2b8f7c12345678901"
}


############
# checkSubscription
GET {{url}}/user/checkSubscription?productId=65f1c9a2b8f7c12345678901
Content-Type: application/json
Authorization: {{token}}

############
# subscriptionProducts
GET {{url}}/user/subscriptionProducts
Content-Type: application/json
