PORT=5000
API_END_POINT_V1=/api
# Prefer MONGO_URI (include database name before ? e.g. .../mydb?retryWrites=true&w=majority)
MONGO_URI=mongodb+srv://<user>:<pass>@<cluster>/grocera?retryWrites=true&w=majority
# Legacy alias (still supported if MONGO_URI is unset)
DB_STRING=mongodb+srv://<user>:<pass>@<cluster>/grocera?retryWrites=true&w=majority
JWT_SECRET_KEY=<strong-secret>
FRONTEND_URL=https://your-frontend-project.vercel.app

STRIPE_SECRET_KEY=<stripe-secret>
STRIPE_WEBHOOK_SECRET=<stripe-webhook-secret>

EMAIL_USER=<smtp-user>
EMAIL_PASS=<smtp-pass>

CLOUDNARY_CLOUD_NAME=<cloud-name>
CLOUDNARY_API_KEY=<api-key>
CLOUDNARY_API_SECRET=<api-secret>

# Optional: managed Redis (Upstash, etc.). If unset, cache/rate-limit stubs avoid connecting to localhost on Vercel.
# REDIS_URL=rediss://default:password@xxx.upstash.io:6379
# Or: REDIS_HOST=127.0.0.1 REDIS_PORT=6379 (local dev)
