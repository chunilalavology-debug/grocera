# =============================================================================
# Production template — copy values into your host (Vercel/Railway/VM). Never commit real secrets.
# Local development: use `.env` from `.env.example` instead.
# =============================================================================

NODE_ENV=production

# If port 5000 is taken (common on macOS), use 5001 and point the frontend at the same port.
PORT=5000
API_END_POINT_V1=/api

# MongoDB (include database name in path). Code accepts MONGO_URI and/or DB_STRING.
MONGO_URI=mongodb+srv://<user>:<pass>@<cluster>/<db>?retryWrites=true&w=majority
DB_STRING=mongodb+srv://<user>:<pass>@<cluster>/<db>?retryWrites=true&w=majority

JWT_SECRET_KEY=<use-a-long-random-string>

# CORS: exact storefront origin(s), no trailing slash. Comma-separated for multiple.
FRONTEND_URL=https://your-production-frontend.example.com
# FRONTEND_URLS=https://preview-1.vercel.app,https://preview-2.vercel.app

# When behind a proxy, public URL for absolute links to uploads/branding (no path, no trailing slash).
# API_PUBLIC_URL=https://your-api-public-domain.example.com
#
# Emails / PDFs: logo path /user/site-branding/logo is resolved as API_PUBLIC_URL + /api + path.
# Optional override (full API root including /api if your mount is non-standard):
# EMAIL_ASSET_BASE_URL=https://your-api-public-domain.example.com/api
# INVOICE_LOGO_URL=https://your-api-public-domain.example.com/api/user/site-branding/logo

# Redis — required on most serverless hosts (Upstash, etc.).
# REDIS_URL=rediss://default:<password>@<host>:6379

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_WEBHOOK_DEBUG=1

# Email (Nodemailer)
EMAIL_USER=<smtp-or-app-user>
EMAIL_PASS=<smtp-or-app-password>
# CONTACT_FORM_TO_EMAIL=orders@yourdomain.com

# Cloudinary
CLOUDNARY_CLOUD_NAME=<name>
CLOUDNARY_API_KEY=<key>
CLOUDNARY_API_SECRET=<secret>

# ----------------------------------------------------------------------------
# Shipping (optional for grocery catalog; improves live quotes)
# ----------------------------------------------------------------------------
# EASYSHIP_API_KEY=<token>
# EASYSHIP_QUOTE_MARKUP_PERCENT=30
# EASYSHIP_QUOTE_MARKUP_MULTIPLIER=1.3
# EASYSHIP_APPLY_SHIPPING_RULES=1
# EASYSHIP_RATES_DEBUG=1

# Shipping proxy (/shipping/get-rates): rate limit per IP/minute
# SHIPPING_PROXY_RATE_LIMIT_PER_MIN=60

# ----------------------------------------------------------------------------
# Logging (Winston). Default production: warn+ to files; Vercel console = errors only unless set.
# LOG_LEVEL=error | warn | info | debug
# ----------------------------------------------------------------------------
