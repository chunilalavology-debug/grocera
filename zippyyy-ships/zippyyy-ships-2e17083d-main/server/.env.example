PORT=3001
APP_URL=http://localhost:8080

# Easyship (Sandbox token usually starts with sand_)
EASYSHIP_API_KEY=sand_your_token_here

# Stripe
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Markup multiplier applied to Easyship rate total (default 1.25 = +25%)
ZIPPYYY_MARKUP_MULTIPLIER=1.25

# Optional fee added on top of Easyship charge (in cents)
ZIPPYYY_FEE_CENTS=0

