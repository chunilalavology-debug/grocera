{
  "name": "rbs-grocery-frontend",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "24.x"
  },
  "dependencies": {
    "axios": "^1.5.0",
    "framer-motion": "^12.34.3",
    "fuse.js": "^7.1.0",
    "lottie-react": "^2.4.1",
    "lucide-react": "^0.563.0",
    "quill": "^2.0.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.6.0",
    "react-quill": "^2.0.0",
    "react-router-dom": "^6.15.0",
    "react-scripts": "^5.0.1",
    "react-select": "^5.10.2",
    "react-window": "^2.2.3",
    "react-window-infinite-loader": "^2.0.0",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "react-scripts start",
    "cache:clear": "node -e \"const fs=require('fs');const p=require('path').join('node_modules','.cache');try{fs.rmSync(p,{recursive:true,force:true});console.log('Cleared webpack cache:',p);}catch(e){console.log('No .cache to clear');}\"",
    "start:fresh": "npm run cache:clear && react-scripts start",
    "build": "cross-env CI=true react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "autoprefixer": "^10.4.24",
    "cross-env": "^7.0.3",
    "http-proxy-middleware": "^2.0.9",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.4"
  }
}
