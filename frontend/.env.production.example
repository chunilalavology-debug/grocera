# =============================================================================
# Production build — CRA bakes these in at `npm run build`. Rebuild after any change.
# =============================================================================

# --- API base (pick ONE strategy) ---

# (1) Same host: UI and JSON API share origin; reverse proxy forwards /api → Node.
# REACT_APP_SAME_ORIGIN_API=1

# (2) API on another host (must return JSON, not HTML):
# REACT_APP_API_URL=https://your-backend.example.com/api

# Optional fallback if primary is missing at build time (must end with /api):
# REACT_APP_API_FALLBACK_URL=https://your-backend.example.com/api

# Public API origin for absolute asset URLs when needed (no trailing slash).
# REACT_APP_API_PUBLIC_URL=https://your-backend.example.com

# -----------------------------------------------------------------------------
# Zippyyy Ships (storefront proxy / Vercel serverless routes to ships API)
# -----------------------------------------------------------------------------
# SHIPS_API_BASE=https://your-ships-api.example.com

# Local dev only (CRA proxy): ships server for /api/quotes
# REACT_APP_SHIPS_API_PROXY=http://127.0.0.1:3001

# -----------------------------------------------------------------------------
# Browser console: by default production silences log/debug/info (see src/bootstrapConsole.js).
# Set to 1 to keep full console logging in production builds (support only).
# REACT_APP_DEBUG=1

# -----------------------------------------------------------------------------
# Notes
# -----------------------------------------------------------------------------
# - Easyship markup (EASYSHIP_QUOTE_MARKUP_*) belongs on the grocery Node API, not here.
# - After editing, run: npm run build
