# Copy to .env.local (gitignored) for local dev.
# Backend must be running (default http://localhost:5000).

REACT_APP_API_URL=http://localhost:5000/api

# Backend (production): public browser-reachable origin for uploaded files (no trailing slash).
# Set when Node sees an internal Host header but users load https://yourdomain.com — fixes profile photos 404.
# API_PUBLIC_URL=https://yourdomain.com

# If Windows port 5000 is in use, run backend with PORT=5001 and set:
# REACT_APP_API_URL=http://localhost:5001/api

# --- "API call returned a web page (wrong base URL)" (profile upload / API returns HTML) ---
#
# The UI must call your real Node API (JSON), not the static index.html.
#
# A) Same website: React at https://yoursite.com and API at https://yoursite.com/api (nginx/Caddy proxies /api → Node)
#    Set at BUILD time (Vercel / .env.production.local), then rebuild:
#    REACT_APP_SAME_ORIGIN_API=1
#    (also accepted: true, yes)
#
# B) API on another URL (no /api on the same host):
#    REACT_APP_API_URL=https://your-api-host.example.com/api
#    Must include /api at the end (or use origin only: https://host — we append /api if path is empty).
#
# After changing env vars, run `npm run build` again (CRA bakes them in at build time).

# Production: verbose browser console (default off). See src/bootstrapConsole.js.
# REACT_APP_DEBUG=1
