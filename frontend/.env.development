# Local Create React App defaults (safe to commit — no secrets)
PORT=3000
REACT_APP_API_URL=http://localhost:5000/api
# If backend cannot use 5000 (Windows port conflict / AirPlay), set backend PORT=5001 and in .env.local:
# REACT_APP_API_URL=http://localhost:5001/api
# (setupProxy uses that URL for localhost so /api on :3000 forwards to the right port.)
