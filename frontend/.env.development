# Local Create React App defaults (safe to commit — no secrets)
PORT=3000
# Target for setupProxy (where the real Node API listens). Axios in dev always uses same-origin /api
# (http://<however-you-open-the-ui>:3000/api) so machine-name URLs like http://DESKTOP-PC:3000 still work.
REACT_APP_API_URL=http://localhost:5000/api
REACT_APP_GROCERY_API_PROXY=http://127.0.0.1:5000
# If backend cannot use 5000 (Windows port conflict / AirPlay), set backend PORT=5001 and point both:
# REACT_APP_API_URL=http://localhost:5001/api
# REACT_APP_GROCERY_API_PROXY=http://127.0.0.1:5001
# To call the API URL below directly from the browser (skip proxy), set: REACT_APP_FORCE_REMOTE_API=1
